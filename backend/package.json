        "ts-node": "^10.9.2",
        "typescript": "^6.0.3"
    },
    "devDependencies": {
        "@types/node": "^25.6.2",
        "@types/socket.io": "^3.0.1",
        "concurrently": "^9.2.1",
        "jest": "^30.3.0",
        "nodemon": "^3.1.14",
        "socket.io-client": "^4.8.3",
        "supertest": "^7.2.2"
    }
