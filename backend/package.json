{
    "name": "ft_transcendence-backend",
    "version": "1.0.0",
    "description": "Backend for ft_transcendence, a 42 project. Provides an Express API and Socket.IO server for real-time communication.",
    "main": "server/index.js",
    "directories": {
        "test": "tests"
    },
    "scripts": {
        "build": "tsc",
        "start": "npm run build && node dist/server/index.js",
