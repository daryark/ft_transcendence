// Visit https://aka.ms/tsconfig to read more about this file
{
  "compilerOptions": {
    "target": "ES2020",
    "module": "node16",

    "moduleResolution": "node16",

    "rootDir": "./",
    "outDir": "./dist",

    "allowJs": true,
    "checkJs": false,

    "esModuleInterop": true,

    "strict": true,
    "skipLibCheck": true
  },
  "include": [
    "game/**/*",
    "sockets/**/*",
    "server/**/*",
    "app.js"
  ],
  "exclude": ["node_modules", "dist", "tests"],
  "ignoreDeprecations": "6.0"
}