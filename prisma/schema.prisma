generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model users {
  id                                   Int             @id @default(autoincrement())
  email                                String          @unique @db.VarChar(255)
  username                             String          @unique @db.VarChar(100)
  password_hash                        String          @db.VarChar(255)
  created_at                           DateTime?       @default(now()) @db.Timestamp(6)
  friends_friends_friend_idTousers     friends[]       @relation("friends_friend_idTousers")
  friends_friends_user_idTousers       friends[]       @relation("friends_user_idTousers")
  match_players                        match_players[]
  messages_messages_receiver_idTousers messages[]      @relation("messages_receiver_idTousers")
  messages_messages_sender_idTousers   messages[]      @relation("messages_sender_idTousers")
}

model friends {
  id                             Int            @id @default(autoincrement())
  user_id                        Int
  friend_id                      Int
  status                         friend_status? @default(pending)
  created_at                     DateTime?      @default(now()) @db.Timestamp(6)
  users_friends_friend_idTousers users          @relation("friends_friend_idTousers", fields: [friend_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_friends_friend")
  users_friends_user_idTousers   users          @relation("friends_user_idTousers", fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_friends_user")

  @@unique([user_id, friend_id], map: "unique_friendship")
}

model match_players {
  id       Int            @id @default(autoincrement())
  match_id Int
  user_id  Int
  score    Int?           @default(0)
  result   player_result?
  matches  matches        @relation(fields: [match_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_match_players_match")
  users    users          @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_match_players_user")
}

model matches {
  id            Int             @id @default(autoincrement())
  status        match_status?   @default(active)
  created_at    DateTime?       @default(now()) @db.Timestamp(6)
  match_players match_players[]
}

model messages {
  id                                Int       @id @default(autoincrement())
  sender_id                         Int
  receiver_id                       Int
  content                           String
  created_at                        DateTime? @default(now()) @db.Timestamp(6)
  users_messages_receiver_idTousers users     @relation("messages_receiver_idTousers", fields: [receiver_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_messages_receiver")
  users_messages_sender_idTousers   users     @relation("messages_sender_idTousers", fields: [sender_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_messages_sender")
}

enum friend_status {
  pending
  accepted
  blocked
}

enum match_status {
  active
  finished
}

enum player_result {
  win
  lose
  draw
}
